# AudioMix Environment Configuration
# Copy this file to .env and fill in your values.

# ─── Backend ─────────────────────────────────────────────────────────────────

# Directory where uploaded audio files are stored.
# Default: /tmp/smart_mix_uploads
UPLOAD_DIR=/tmp/smart_mix_uploads

# Port the FastAPI server listens on.
# Default: 8000
PORT=8000

# Allowed CORS origins (comma-separated). Use * for open access during development.
# Default: *
CORS_ORIGINS=*

# ─── Frontend ────────────────────────────────────────────────────────────────

# Base URL of the backend API as seen by the browser.
# Default: http://localhost:8000/api
VITE_API_BASE=http://localhost:8000/api
